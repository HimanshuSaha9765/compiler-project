# CompilerX - Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to GitHub - it's already in .gitignore

# === LLM Advisor - Phase 8.2 (OPTIONAL) ===
# App works 100% offline without any of these keys.
# Rule-based suggestions still work and can reach 100% Health.

# Option 1 - Groq (RECOMMENDED)
# Get free key at: https://console.groq.com/keys
# Free tier: 30 req/min, 14,400 req/day, no credit card
# Model used: llama-3.1-8b-instant
GROQ_API_KEY=

# Option 2 - Google Gemini (alternative)
# Get free key at: https://aistudio.google.com/app/apikey
# Free tier: 15 RPM, 1M tokens context
# Model used: gemini-1.5-flash
GEMINI_API_KEY=

# Which provider to use: groq / gemini / auto / off
# auto = try GROQ first, then Gemini, then offline
# off = force offline rule-based mode (no API calls)
LLM_PROVIDER=auto

# === Flask (optional) ===
FLASK_ENV=development
SECRET_KEY=compilerx-dev-key-2026
